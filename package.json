{
  "name": "needle-mcp",
  "version": "0.1.0",
  "description": "MCP server that answers questions about undocumented/bleeding-edge libraries by grounding answers in their actual source code",
  "type": "module",
  "bin": {
    "needle-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark": "tsc && node dist/benchmark/run.js",
    "benchmark:sample": "tsc && node dist/benchmark/run.js --sample",
    "benchmark:graphs": "tsc && node dist/benchmark/run.js --graphs-only"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "jsonrepair": "^3.13.2",
    "pacote": "^21.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pacote": "^11.1.8",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
